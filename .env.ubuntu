# =============================================================
# HyperSpace AGI v0.2 — .env per UBUNTU (seed B, 24/7)
# Copia come .env su Ubuntu
# =============================================================

# Ollama sull'host Ubuntu (docker0 bridge su Linux)
OLLAMA_URL=http://172.17.0.1:11434
OLLAMA_MODEL=phi3

# Identità nodo — nome univoco!
NODE_HOSTNAME=node-ubuntu
NODE_PORT=8084
NODE_TIER=hub
VRAM_GB=0.0

# Endpoint pubblico di questo nodo (ngrok statico Ubuntu)
PUBLIC_ENDPOINT=https://sanctuary-mower-plated.ngrok-free.dev

# Boot peers: Mac è il primo seed
BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Control plane sul Mac via Tailscale (Ubuntu -> Mac :8085)
# Il Mac deve esporre la porta 8085 su Tailscale (non bloccata da firewall)
CONTROL_PLANE_URL=http://100.81.234.102:8085

# Nodi pre-configurati
NODE_ENDPOINTS=node:8084

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# Inference backend
INFERENCE_BACKEND=ollama
