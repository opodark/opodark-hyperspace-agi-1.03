# =============================================================
# HyperSpace AGI v1.02 — .env.example
# Copia come .env e personalizza.
#
# Hub Mac:    cp .env.mac .env
# Hub Ubuntu: cp .env.ubuntu .env
# Nodo leaf:  copia questo file, imposta PUBLIC_ENDPOINT e BOOT_PEERS
# =============================================================

# Ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# Identità nodo
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=leaf
VRAM_GB=0.0

# Endpoint pubblico di questo nodo (URL ngrok o IP pubblico)
# Obbligatorio per essere raggiungibile da altri nodi della mesh
PUBLIC_ENDPOINT=

# Boot peers — indirizzi degli hub a cui connettersi all'avvio
# Per nodi leaf: usa entrambi gli hub
BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev,https://sanctuary-mower-plated.ngrok-free.dev

# Control-plane locale
CONTROL_PLANE_URL=http://control-plane:8085

# Registry locale
REGISTRY_URL=http://registry:8086
REGISTRY_PORT=8086

# Heartbeat (secondi)
HEARTBEAT_EVERY=30
HEARTBEAT_INTERVAL=30
NODE_TTL=90

# Firma inter-nodo
SIGN_REQUESTS=true

# Nodi pre-noti al control-plane locale
NODE_ENDPOINTS=node:8084

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

INFERENCE_BACKEND=ollama
