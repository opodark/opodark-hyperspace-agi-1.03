# =============================================================
# HyperSpace AGI v0.2 — .env.example
# Copia come .env e personalizza.
# File pronti: .env.mac e .env.ubuntu
# =============================================================

# Ollama
# macOS:  http://host.docker.internal:11434
# Linux:  http://172.17.0.1:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# Nodo
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=leaf
VRAM_GB=0.0

# Endpoint pubblico ngrok di questo nodo
PUBLIC_ENDPOINT=

# Boot peers (altri seed della rete)
# Mac seed:    https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
# Ubuntu seed: https://sanctuary-mower-plated.ngrok-free.dev
BOOT_PEERS=

# URL del control-plane
# Stesso Docker:      http://control-plane:8085
# Ubuntu -> Mac:      http://100.81.234.102:8085  (Tailscale)
CONTROL_PLANE_URL=http://control-plane:8085

# Nodi pre-configurati nel control-plane
NODE_ENDPOINTS=node:8084

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

INFERENCE_BACKEND=ollama
