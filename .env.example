# HyperSpace AGI v1.01 — cross-platform environment example
# Copy this file to .env and adjust for your setup,
# or let setup.sh generate it automatically.
#
# ── macOS (Ollama installed locally on host) ──────────
#   OLLAMA_URL=http://host.docker.internal:11434
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# ── Linux with Ollama in Docker ───────────────────────
#   OLLAMA_URL=http://ollama:11434
#   OLLAMA_BASE_URL=http://ollama:11434
#
# ── Linux with Ollama on host (systemd service) ───────
#   OLLAMA_URL=http://host.docker.internal:11434
#   OLLAMA_BASE_URL=http://host.docker.internal:11434

AUTHORITY_URL=http://authority:8080
OLLAMA_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3
WEBUI_SECRET_KEY=hyperspace-secret-change-me
