# =============================================================
# HyperSpace AGI v0.2 — .env per MAC (seed A)
# Copia come .env sul Mac
# =============================================================

# Ollama sull'host Mac
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# Identità nodo
NODE_HOSTNAME=node-mac
NODE_PORT=8084
NODE_TIER=hub
VRAM_GB=0.0

# Endpoint pubblico di questo nodo (ngrok statico Mac)
PUBLIC_ENDPOINT=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Boot peers: Ubuntu è il secondo seed permanente
BOOT_PEERS=https://sanctuary-mower-plated.ngrok-free.dev

# Control plane locale (stesso stack Docker)
CONTROL_PLANE_URL=http://control-plane:8085

# Nodi pre-configurati nel control-plane
# Ubuntu si auto-registra via /mesh/announce, ma pre-popoliamo per il polling
NODE_ENDPOINTS=node:8084,sanctuary-mower-plated.ngrok-free.dev

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# Inference backend
INFERENCE_BACKEND=ollama
