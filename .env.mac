# =============================================================
# HyperSpace AGI v1.02 — .env per Mac (hub/authority)
# Questa macchina è un HUB: accetta announce da nodi esterni
# e si annuncia all'hub Ubuntu via ngrok.
# =============================================================

# Ollama (Mac: Ollama nativo)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# Identità nodo
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=hub
VRAM_GB=0.0

# Endpoint pubblico di QUESTO nodo — url ngrok del Mac
# I nodi remoti useranno questo indirizzo per annunciarsi
PUBLIC_ENDPOINT=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Boot peers: il Mac si annuncia all'hub Ubuntu all'avvio
BOOT_PEERS=https://sanctuary-mower-plated.ngrok-free.dev

# Control-plane locale
CONTROL_PLANE_URL=http://control-plane:8085

# Registry locale
REGISTRY_URL=http://registry:8086
REGISTRY_PORT=8086

# Nodi noti al control-plane locale
NODE_ENDPOINTS=node:8084

# Heartbeat ogni 15s (hub: più frequente)
HEARTBEAT_EVERY=15
HEARTBEAT_INTERVAL=15
NODE_TTL=60

# Firma inter-nodo abilitata
SIGN_REQUESTS=true

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

INFERENCE_BACKEND=ollama
